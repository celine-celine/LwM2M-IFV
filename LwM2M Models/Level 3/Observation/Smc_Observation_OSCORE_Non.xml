	<declaration>// 系统规模
const int MAX_CLIENTS = 2;
typedef int[0, MAX_CLIENTS-1] client_id_t;

// 客户端状态
const int CLIENT_STATE_REGISTERED = 5;
const int CLIENT_STATE_OBSERVING = 6;

// 假设 Bootstrap/Registration 已完成
int bootstrap_completed_count = MAX_CLIENTS;
int registration_completed_count = MAX_CLIENTS;

// 广播通道
broadcast chan observe_start[MAX_CLIENTS];
broadcast chan observe_stop[MAX_CLIENTS];
broadcast chan notification[MAX_CLIENTS];

// 概率参数
const double NOTIFICATION_RATE = 0.01;        // 通知发送速率
const int WEIGHT_SUCCESS = 995;               // 成功发送权重
const int WEIGHT_LOSS = 5;                     // 丢包权重

// 时间参数
const int ACK_TIMEOUT = 10000000;              // 远大于仿真时间

// 观察周期（设为足够大，但避免溢出）
const int MAX_OBSERVATION_CYCLES = 1000000;

// 共享变量（扩大范围）
int[0, 200000] notification_sent[MAX_CLIENTS];       // 客户端发送计数
int[0, 200000] notification_received[MAX_CLIENTS];   // 服务器接收计数
int[0, 200000] observation_cycle_count = 0;
bool observation_in_progress = false;
bool observation_completed = false;

// 客户端状态和观察资源（范围小，保持不变）
int client_state[MAX_CLIENTS];
bool client_observed[MAX_CLIENTS];




// 安全延迟常数（时间单位，假设1单位=0.01ms）
const int ENCRYPT_DELAY = 5;    // 加密耗时 0.5ms
const int DECRYPT_DELAY = 4;    // 解密耗时 0.4ms

// 安全启用标志（组B设为 true，组A设为 false）
bool security_enabled = true;</declaration>
