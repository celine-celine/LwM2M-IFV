	<declaration>const int MAX_CLIENTS = 2;
typedef int[0, MAX_CLIENTS-1] client_id_t;

typedef int[0,12] client_state_t;  // 扩展3个写操作状态
const int CLIENT_STATE_INIT = 0;
const int CLIENT_STATE_BOOTSTRAPPING = 1;
const int CLIENT_STATE_BOOTSTRAP_COMPLETE = 2;
const int CLIENT_STATE_REGISTERING = 3;
const int CLIENT_STATE_REGISTER_RECEIVED = 4;
const int CLIENT_STATE_REGISTERED = 5;
const int CLIENT_STATE_OBSERVING = 6;
const int CLIENT_STATE_NOTIFYING = 7;
const int CLIENT_STATE_WRITE_PENDING = 8;     // 新增：等待写请求
const int CLIENT_STATE_WRITE_PROCESSING = 9;  // 新增：处理写请求
const int CLIENT_STATE_WRITE_RESPONDING = 10; // 新增：响应写请求
const int CLIENT_STATE_ERROR = 12;

// 2.2 资源类型定义
typedef int[0,3] resource_id_t;
const int RESOURCE_TEMPERATURE = 0;
const int RESOURCE_STATUS = 1;
const int RESOURCE_PRODUCTION_COUNT = 2;
const int RESOURCE_ALARM = 3;

// 2.3 通道定义
// 原有通道
chan bootstrap_start_client[MAX_CLIENTS];
chan bootstrap_credential[MAX_CLIENTS];
chan bootstrap_config[MAX_CLIENTS];
chan bootstrap_complete[MAX_CLIENTS];
chan register_start[MAX_CLIENTS];
chan register_objects[MAX_CLIENTS];
chan register_complete[MAX_CLIENTS];
chan register_ack[MAX_CLIENTS];

// 新增观察通道
chan observe_start[MAX_CLIENTS];
chan observe_stop[MAX_CLIENTS];
chan notification[MAX_CLIENTS];

// 3.3 新增写操作通道（精简设计）
chan write_request[MAX_CLIENTS];      // 服务器-&gt;客户端：写请求
chan write_response[MAX_CLIENTS];     // 客户端-&gt;服务器：写响应

// 2.4 共享变量（优化用于验证）
client_state_t client_state[MAX_CLIENTS];
bool client_registered[MAX_CLIENTS];
bool client_observed[MAX_CLIENTS];
bool bootstrap_in_progress = false;
bool registration_in_progress = false;
bool observation_in_progress = false;

int bootstrap_completed_count = 0;
int registration_completed_count = 0;
int notification_count = 0;
int observation_cycle_count = 0;

// 添加验证辅助变量
int client_observation_count[MAX_CLIENTS];  // 移到全局，用于公平性验证
bool client_ever_observed[MAX_CLIENTS];     // 记录客户端是否曾被观察

int resource_value[MAX_CLIENTS][4];
int observed_resource[MAX_CLIENTS];

// 减少状态空间：缩小参数范围
const int OBSERVATION_INTERVAL = 3;          // 从5减少到3
const int NOTIFICATION_THRESHOLD = 2;        // 从3减少到2
const int MAX_OBSERVATION_CYCLES = 2;        // 从4减少到2
const int MAX_WRITE_OPERATIONS = 2;


// 3.4 新增共享变量
bool write_in_progress = false;       // 写操作是否进行中
int write_operation_count = 0;        // 写操作计数
int write_target_resource[MAX_CLIENTS]; // 要写入的资源ID
int write_target_value[MAX_CLIENTS];    // 要写入的值
bool write_completed[MAX_CLIENTS];      // 写操作是否完成

bool observation_completed = false;
</declaration>
