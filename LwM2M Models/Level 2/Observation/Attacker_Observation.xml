<nta>
	<declaration>// 系统规模
const int MAX_CLIENTS = 2;
typedef int[0, MAX_CLIENTS-1] client_id_t;

// 客户端状态（保留Level1中的Observation相关状态）
const int CLIENT_STATE_REGISTERED = 5;
const int CLIENT_STATE_OBSERVING = 6;
const int CLIENT_STATE_NOTIFYING = 7;

// 攻击模式
const int NO_ATTACK = 0;
const int TAMPER_NOTIFY = 1;   // 篡改通知内容
const int REPLAY_NOTIFY = 2;

int attack_mode = TAMPER_NOTIFY;

// 简化Bootstrap/Registration：假设已完成
bool client_registered[MAX_CLIENTS];   // 初始化为true
int bootstrap_completed_count = MAX_CLIENTS;  // 假设已完成
int registration_completed_count = MAX_CLIENTS;

// Observation相关通道（与Level1一致）
chan observe_start[MAX_CLIENTS];
chan observe_stop[MAX_CLIENTS];
chan notification[MAX_CLIENTS];

// 攻击者专用通道（用于拦截和篡改）
chan client_to_attacker_notify[MAX_CLIENTS];
chan attacker_to_server_notify[MAX_CLIENTS];

// 共享变量
int client_state[MAX_CLIENTS];
bool client_observed[MAX_CLIENTS];
int notification_count = 0;
int observation_cycle_count = 0;
bool observation_in_progress = false;
bool observation_completed = false;

// 资源值模拟
int resource_value[MAX_CLIENTS][4];
int observed_resource[MAX_CLIENTS];

// 通知阈值等（简化）
const int NOTIFICATION_THRESHOLD = 2;
const int MAX_OBSERVATION_CYCLES = 2;

// 篡改攻击变量
bool notification_tampered[MAX_CLIENTS];
int tampered_value[MAX_CLIENTS];
const int NORMAL_THRESHOLD = 2;      // 正常阈值
const int TAMPERED_THRESHOLD = 5;    // 篡改后的阈值（例如，使客户端误以为未达到触发条件）

// 观察周期计数
int client_observation_count[MAX_CLIENTS];

// 简化：假设资源值初始为0
bool notification_recorded[MAX_CLIENTS];    // 是否已记录通知
int recorded_value[MAX_CLIENTS];            // 记录的通知值（如有）
int replay_count = 0;
const int MAX_REPLAY = 3;                    // 最大重放次数

chan client_to_attacker_notify_replay[MAX_CLIENTS];
chan attacker_to_server_replay[MAX_CLIENTS];
</declaration>
