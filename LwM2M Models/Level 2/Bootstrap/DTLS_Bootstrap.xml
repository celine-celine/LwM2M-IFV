	<declaration>// 常量定义
const int MAX_CLIENTS = 2;
typedef int[0, MAX_CLIENTS-1] client_id_t;

// 客户端状态
const int CLIENT_STATE_INIT = 0;
const int CLIENT_STATE_BOOTSTRAPPING = 1;
const int CLIENT_STATE_BOOTSTRAP_COMPLETE = 2;
const int CLIENT_STATE_ERROR = 12;


// 调试阶段常量
const int PHASE_INIT = 0;
const int PHASE_CREDENTIAL = 1;      // 在 S_BOOTSTRAP_CREDENTIAL
const int PHASE_WAITING_CONFIG = 2;   // 在 S_WAITING_CONFIG
const int PHASE_VERIFY = 3;           // 在 S_VERIFY_CONFIG
const int PHASE_DONE = 4;             // 在 S_BOOTSTRAP_DONE
const int PHASE_ERROR = 5;            // 在 S_ERROR

int client_phase[MAX_CLIENTS];        // 初始默认为0（INIT）

// 攻击模式
const int NO_ATTACK = 0;
const int MITM_ATTACK = 1;
const int EAVESDROP_ATTACK = 2;
const int FAKE_BS_ATTACK = 3;
int attack_mode = FAKE_BS_ATTACK;   // 可手动切换

// 标准 Bootstrap 通道（与 Level1 一致）
chan bootstrap_start_client[MAX_CLIENTS];
chan bootstrap_credential[MAX_CLIENTS];
chan bootstrap_config[MAX_CLIENTS];

// MITM 攻击专用通道（每个客户端独立）
chan client_to_attacker_start[MAX_CLIENTS];
chan attacker_to_server_start[MAX_CLIENTS];
chan client_to_attacker_credential[MAX_CLIENTS];
chan attacker_to_server_credential[MAX_CLIENTS];
chan server_to_attacker_config[MAX_CLIENTS];
chan attacker_to_client_config[MAX_CLIENTS];

broadcast chan bootstrap_success[MAX_CLIENTS];
broadcast chan bootstrap_error[MAX_CLIENTS];

//BS chan
chan fake_bs_start[MAX_CLIENTS];
chan fake_bs_config[MAX_CLIENTS];


// 共享变量
int client_state[MAX_CLIENTS];
bool client_bootstrapped[MAX_CLIENTS];
int bootstrap_completed_count = 0;
bool bootstrap_in_progress = false;

// MITM 攻击变量
bool mitm_active = false;
int intercepted_messages = 0;
const int MAX_INTERCEPTIONS = 10;
bool message_tampered[MAX_CLIENTS];
int tampered_config_value[MAX_CLIENTS];
const int NORMAL_CONFIG = 100;
const int TAMPERED_CONFIG = 999;
const int FAKE_CONFIG = 666;
bool config_verified[MAX_CLIENTS];

// 客户端内部变量（用于验证）
int received_config[MAX_CLIENTS];

// 服务器内部变量
bool client_processed[MAX_CLIENTS];
int current_client = 0;

//BS
int client_bs_type[MAX_CLIENTS];

//EAVESDROP
bool credential_on_wire[MAX_CLIENTS];      // 凭证在网络上传输时置为true
bool credential_leaked[MAX_CLIENTS];       // 凭证已被窃听者获取
int eavesdrop_count = 0;                    // 窃听次数计数
const int MAX_EAVESDROP = 10;                // 最大窃听次数（可选）


// DTLS 握手相关
bool dtls_enabled = true;                       // 是否启用 DTLS 握手
bool dtls_established[MAX_CLIENTS];             // 客户端与服务器之间 DTLS 是否已建立
chan dtls_client_hello[MAX_CLIENTS];            // 客户端 -&gt; 服务器：ClientHello
chan dtls_server_hello[MAX_CLIENTS];            // 服务器 -&gt; 客户端：ServerHello
// 可选：记录DTLS阻止的攻击次数
int dtls_attack_blocked = 0;</declaration>
