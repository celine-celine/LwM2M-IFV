	<declaration>// ================ Level2-2: Registration安全模型（完整修正版） ================

// 1.1 系统规模定义
const int MAX_CLIENTS = 2;
typedef int[0, MAX_CLIENTS-1] client_id_t;

// 1.2 客户端状态
typedef int[0,5] client_state_t;
const int CLIENT_STATE_INIT = 0;
const int CLIENT_STATE_BOOTSTRAP_COMPLETE = 1;
const int CLIENT_STATE_REGISTERING = 2;
const int CLIENT_STATE_REGISTER_RECEIVED = 3;
const int CLIENT_STATE_REGISTERED = 4;
const int CLIENT_STATE_ERROR = 5;

// 1.3 攻击者类型
typedef int[0,2] attacker_mode_t;
const int NO_ATTACK = 0;
const int REPLAY_ATTACK = 1;
const int DOS_ATTACK = 2;

// 1.4 全局攻击模式变量（可根据需要修改）
attacker_mode_t attack_mode = DOS_ATTACK;  // 默认无攻击

// 1.5 通道定义
chan register_start[MAX_CLIENTS];
chan register_objects[MAX_CLIENTS];
chan register_complete[MAX_CLIENTS];
chan register_ack[MAX_CLIENTS];
chan attack_register_start;

// 1.6 共享变量
client_state_t client_state[MAX_CLIENTS];
bool client_registered[MAX_CLIENTS];
bool registration_in_progress = false;
bool bootstrap_completed = false;
int bootstrap_completed_count = 0;
int registration_completed_count = 0;

// 安全相关变量
bool attack_detected = false;
int attack_counter = 0;
const int MAX_ATTACKS = 2;

// 消息序列号机制
int client_message_id[MAX_CLIENTS];
int server_last_msg_id[MAX_CLIENTS];

// 攻击者检测标志
bool registration_handler_waiting = false;

// DoS特定变量
bool dos_throttling_active = false;
int dos_cooldown_counter = 0;
const int DOS_COOLDOWN_PERIOD = 3;

// 消息验证变量（全局）
bool message_fresh = false;
bool is_valid_client_request = false;
bool is_dos_condition = false;

// 重放攻击特定变量
bool replay_message_detected = false;
int replay_counter = 0;
const int MAX_REPLAY_ATTEMPTS = 1;

// 公平性保证变量
bool client_given_chance[MAX_CLIENTS];
int client_attempt_count[MAX_CLIENTS];
const int MAX_CLIENT_ATTEMPTS = 2;

// 调试变量
bool debug_attack_received = false;
int debug_attack_attempts = 0;
bool debug_dos_triggered = false;
bool debug_replay_detected = false;
bool debug_attacker_active = false;</declaration>
