<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.6//EN' 'http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd'>
<nta>
	<declaration>// Registration lifecycle profile model.
// The model extends initial Registration with Update-based lifetime renewal
// and server-side expiration of stale registrations.

const int MAX_CLIENTS = 1;
typedef int[0, MAX_CLIENTS-1] client_id_t;

const int CLIENT_STATE_BOOTSTRAP_COMPLETE = 1;
const int CLIENT_STATE_REGISTERING = 2;
const int CLIENT_STATE_REGISTERED = 4;
const int CLIENT_STATE_UPDATING = 6;
const int CLIENT_STATE_EXPIRED = 7;

const int LIFETIME = 100;
const int UPDATE_EARLY = 60;
const int MAX_UPDATES = 2;

chan register_start[MAX_CLIENTS];
chan register_objects[MAX_CLIENTS];
chan register_ack[MAX_CLIENTS];
chan update_start[MAX_CLIENTS];
chan update_ack[MAX_CLIENTS];

bool bootstrap_completed[MAX_CLIENTS];
bool client_registered[MAX_CLIENTS];
bool object_list_received[MAX_CLIENTS];
bool registration_ack_received[MAX_CLIENTS];
bool update_request_received[MAX_CLIENTS];
bool update_ack_received[MAX_CLIENTS];
bool lifetime_renewed[MAX_CLIENTS];
bool lifetime_expired[MAX_CLIENTS];
bool server_session_active[MAX_CLIENTS];
bool command_authorized[MAX_CLIENTS];
int client_state[MAX_CLIENTS];
int client_message_id[MAX_CLIENTS];
int server_last_msg_id[MAX_CLIENTS];
int[0, MAX_UPDATES] update_count[MAX_CLIENTS];
</declaration>
	<template>
		<name x="5" y="5">Client</name>
		<parameter>const client_id_t id</parameter>
		<declaration>clock t;</declaration>
		<location id="id0" x="-760" y="80">
			<name x="-770" y="46">S_BOOTSTRAP_DONE</name>
		</location>
		<location id="id1" x="-500" y="80">
			<name x="-560" y="46">S_SEND_REGISTER</name>
			<committed/>
		</location>
		<location id="id2" x="-240" y="80">
			<name x="-300" y="46">S_SEND_OBJECTS</name>
			<committed/>
		</location>
		<location id="id3" x="20" y="80">
			<name x="-30" y="46">S_WAIT_ACK</name>
		</location>
		<location id="id4" x="300" y="0">
			<name x="260" y="-34">S_REGISTERED</name>
		</location>
		<location id="id5" x="580" y="0">
			<name x="520" y="-34">S_SEND_UPDATE</name>
			<committed/>
		</location>
		<location id="id6" x="840" y="0">
			<name x="790" y="-34">S_WAIT_UPDATE_ACK</name>
		</location>
		<location id="id7" x="580" y="180">
			<name x="540" y="146">S_EXPIRED</name>
		</location>
		<init ref="id0"/>
		<transition id="id8">
			<source ref="id0"/>
			<target ref="id1"/>
			<label kind="guard" x="-750" y="20">bootstrap_completed[id]</label>
			<label kind="assignment" x="-750" y="40">client_state[id] = CLIENT_STATE_REGISTERING,
client_message_id[id] = client_message_id[id] + 1,
t = 0</label>
		</transition>
		<transition id="id9">
			<source ref="id1"/>
			<target ref="id2"/>
			<label kind="synchronisation" x="-490" y="50">register_start[id]!</label>
		</transition>
		<transition id="id10">
			<source ref="id2"/>
			<target ref="id3"/>
			<label kind="synchronisation" x="-230" y="50">register_objects[id]!</label>
		</transition>
		<transition id="id11">
			<source ref="id3"/>
			<target ref="id4"/>
			<label kind="synchronisation" x="30" y="0">register_ack[id]?</label>
			<label kind="assignment" x="30" y="20">registration_ack_received[id] = true,
client_registered[id] = true,
client_state[id] = CLIENT_STATE_REGISTERED,
t = 0</label>
		</transition>
		<transition id="id12">
			<source ref="id4"/>
			<target ref="id5"/>
			<label kind="guard" x="310" y="-90">t &gt;= UPDATE_EARLY &amp;&amp; t &lt; LIFETIME &amp;&amp;
update_count[id] &lt; MAX_UPDATES &amp;&amp; !lifetime_expired[id]</label>
			<label kind="assignment" x="310" y="-50">client_state[id] = CLIENT_STATE_UPDATING,
client_message_id[id] = client_message_id[id] + 1</label>
		</transition>
		<transition id="id13">
			<source ref="id5"/>
			<target ref="id6"/>
			<label kind="synchronisation" x="590" y="-30">update_start[id]!</label>
		</transition>
		<transition id="id14">
			<source ref="id6"/>
			<target ref="id4"/>
			<label kind="synchronisation" x="610" y="40">update_ack[id]?</label>
			<label kind="assignment" x="610" y="60">update_ack_received[id] = true,
lifetime_renewed[id] = true,
client_state[id] = CLIENT_STATE_REGISTERED,
update_count[id] = update_count[id] + 1,
t = 0</label>
		</transition>
		<transition id="id15">
			<source ref="id4"/>
			<target ref="id7"/>
			<label kind="guard" x="310" y="150">lifetime_expired[id]</label>
			<label kind="assignment" x="310" y="170">client_registered[id] = false,
client_state[id] = CLIENT_STATE_EXPIRED</label>
		</transition>
		<transition id="id16">
			<source ref="id7"/>
			<target ref="id7"/>
			<nail x="520" y="240"/>
			<nail x="640" y="240"/>
		</transition>
	</template>
	<template>
		<name x="5" y="5">RegistrationServer</name>
		<parameter>const client_id_t id</parameter>
		<declaration>clock lt;</declaration>
		<location id="id17" x="-760" y="-320">
			<name x="-770" y="-354">S_INIT</name>
			<committed/>
		</location>
		<location id="id18" x="-500" y="-320">
			<name x="-560" y="-354">S_WAIT_REGISTER</name>
		</location>
		<location id="id19" x="-240" y="-320">
			<name x="-300" y="-354">S_WAIT_OBJECTS</name>
		</location>
		<location id="id20" x="20" y="-320">
			<name x="-40" y="-354">S_VALIDATE</name>
			<committed/>
		</location>
		<location id="id21" x="300" y="-320">
			<name x="240" y="-354">S_SEND_ACK</name>
			<committed/>
		</location>
		<location id="id22" x="580" y="-320">
			<name x="540" y="-354">S_ACTIVE</name>
			<label kind="invariant" x="540" y="-300">lt &lt;= LIFETIME</label>
		</location>
		<location id="id23" x="840" y="-420">
			<name x="780" y="-454">S_VALIDATE_UPDATE</name>
			<committed/>
		</location>
		<location id="id24" x="1100" y="-420">
			<name x="1040" y="-454">S_SEND_UPDATE_ACK</name>
			<committed/>
		</location>
		<location id="id25" x="840" y="-180">
			<name x="800" y="-214">S_EXPIRED</name>
		</location>
		<init ref="id17"/>
		<transition id="id26">
			<source ref="id17"/>
			<target ref="id18"/>
			<label kind="assignment" x="-750" y="-300">bootstrap_completed[id] = true,
client_state[id] = CLIENT_STATE_BOOTSTRAP_COMPLETE</label>
		</transition>
		<transition id="id27">
			<source ref="id18"/>
			<target ref="id19"/>
			<label kind="synchronisation" x="-490" y="-350">register_start[id]?</label>
		</transition>
		<transition id="id28">
			<source ref="id19"/>
			<target ref="id20"/>
			<label kind="synchronisation" x="-230" y="-350">register_objects[id]?</label>
			<label kind="assignment" x="-230" y="-330">object_list_received[id] = true</label>
		</transition>
		<transition id="id29">
			<source ref="id20"/>
			<target ref="id21"/>
			<label kind="guard" x="20" y="-390">client_message_id[id] &gt; server_last_msg_id[id]</label>
			<label kind="assignment" x="20" y="-370">server_last_msg_id[id] = client_message_id[id]</label>
		</transition>
		<transition id="id30">
			<source ref="id21"/>
			<target ref="id22"/>
			<label kind="synchronisation" x="310" y="-350">register_ack[id]!</label>
			<label kind="assignment" x="310" y="-330">server_session_active[id] = true,
command_authorized[id] = true,
lt = 0</label>
		</transition>
		<transition id="id31">
			<source ref="id22"/>
			<target ref="id23"/>
			<label kind="guard" x="590" y="-430">lt &lt; LIFETIME</label>
			<label kind="synchronisation" x="590" y="-410">update_start[id]?</label>
			<label kind="assignment" x="590" y="-390">update_request_received[id] = true</label>
		</transition>
		<transition id="id32">
			<source ref="id23"/>
			<target ref="id24"/>
			<label kind="guard" x="850" y="-490">client_message_id[id] &gt; server_last_msg_id[id]</label>
			<label kind="assignment" x="850" y="-470">server_last_msg_id[id] = client_message_id[id]</label>
		</transition>
		<transition id="id33">
			<source ref="id24"/>
			<target ref="id22"/>
			<label kind="synchronisation" x="1110" y="-350">update_ack[id]!</label>
			<label kind="assignment" x="1110" y="-330">server_session_active[id] = true,
command_authorized[id] = true,
lt = 0</label>
		</transition>
		<transition id="id34">
			<source ref="id22"/>
			<target ref="id25"/>
			<label kind="guard" x="590" y="-210">lt &gt;= LIFETIME</label>
			<label kind="assignment" x="590" y="-190">lifetime_expired[id] = true,
server_session_active[id] = false,
command_authorized[id] = false,
update_ack_received[id] = false</label>
		</transition>
		<transition id="id35">
			<source ref="id25"/>
			<target ref="id25"/>
			<nail x="780" y="-120"/>
			<nail x="900" y="-120"/>
		</transition>
	</template>
	<system>Client0 = Client(0);
RegistrationServer0 = RegistrationServer(0);

system Client0, RegistrationServer0;</system>
	<queries>
		<query>
			<formula>A[] not deadlock</formula>
			<comment>Deadlock freedom for registration lifecycle.</comment>
		</query>
		<query>
			<formula>E&lt;&gt; update_ack_received[0]</formula>
			<comment>A registered client can renew its registration lifetime via Update.</comment>
		</query>
		<query>
			<formula>E&lt;&gt; lifetime_expired[0]</formula>
			<comment>The server can expire a stale registration if no timely Update is performed.</comment>
		</query>
		<query>
			<formula>A[] lifetime_expired[0] imply !server_session_active[0]</formula>
			<comment>An expired registration cannot remain an active server session.</comment>
		</query>
		<query>
			<formula>A[] command_authorized[0] imply server_session_active[0] and !lifetime_expired[0]</formula>
			<comment>Industrial commands are authorized only for active non-expired registrations.</comment>
		</query>
		<query>
			<formula>A[] (lifetime_renewed[0] and !lifetime_expired[0]) imply client_registered[0]</formula>
			<comment>A renewed non-expired lifetime belongs to a registered client.</comment>
		</query>
		<query>
			<formula>E&lt;&gt; update_count[0] == MAX_UPDATES and server_session_active[0]</formula>
			<comment>The bounded lifecycle can cover multiple successful Update cycles.</comment>
		</query>
	</queries>
</nta>
