<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC '-//Uppaal Team//DTD Flat System 1.6//EN' 'http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd'>
<nta>
	<declaration>// Improved Observation flow model.
// This generated model keeps a long-lived Observe relation across multiple Notify messages
// and adds an abstract CoAP ACK/Reset response path.

const int MAX_CLIENTS = 2;
typedef int[0, MAX_CLIENTS-1] client_id_t;

const int CLIENT_STATE_REGISTERED = 5;
const int CLIENT_STATE_OBSERVING = 6;
const int CLIENT_STATE_NOTIFYING = 7;

const int MAX_NOTIFICATIONS_PER_OBSERVATION = 2;
const bool RESET_ENABLED = true;

int registration_completed_count = MAX_CLIENTS;

chan observe_start[MAX_CLIENTS];
chan observe_stop[MAX_CLIENTS];
chan notification[MAX_CLIENTS];
chan coap_ack[MAX_CLIENTS];
chan coap_reset[MAX_CLIENTS];

int client_state[MAX_CLIENTS];
bool client_observed[MAX_CLIENTS];
bool reset_received[MAX_CLIENTS];
bool observation_completed = false;

int notification_sent[MAX_CLIENTS];
int notification_received[MAX_CLIENTS];
int ack_sent[MAX_CLIENTS];
int reset_sent[MAX_CLIENTS];
</declaration>
	<template>
		<name x="5" y="5">ObservationHandler</name>
		<declaration>int current_client = 0;
int selected_client = 0;
int current_notifications = 0;</declaration>
		<location id="id0" x="-779" y="-481">
			<name x="-789" y="-515">S_IDLE</name>
		</location>
		<location id="id1" x="-782" y="-297">
			<name x="-842" y="-331">S_SELECT_CLIENT</name>
			<committed/>
		</location>
		<location id="id2" x="-467" y="-297">
			<name x="-527" y="-331">S_START_OBSERVE</name>
			<committed/>
		</location>
		<location id="id3" x="-204" y="-297">
			<name x="-274" y="-331">S_WAIT_NOTIFY</name>
		</location>
		<location id="id4" x="167" y="-294">
			<name x="107" y="-328">S_DECIDE_RESPONSE</name>
			<committed/>
		</location>
		<location id="id5" x="-68" y="-493">
			<name x="-128" y="-527">S_SEND_ACK_CONTINUE</name>
			<committed/>
		</location>
		<location id="id6" x="447" y="-294">
			<name x="382" y="-331">S_SEND_ACK_CANCEL</name>
			<committed/>
		</location>
		<location id="id7" x="450" y="-187">
			<name x="390" y="-221">S_SEND_RESET</name>
			<committed/>
		</location>
		<location id="id8" x="731" y="-297">
			<name x="671" y="-331">S_CANCEL_OBSERVE</name>
			<committed/>
		</location>
		<location id="id9" x="-782" y="-59">
			<name x="-792" y="-93">S_COMPLETED</name>
		</location>
		<init ref="id0"/>
		<transition id="id10">
			<source ref="id0"/>
			<target ref="id1"/>
			<label kind="guard" x="-983" y="-472">registration_completed_count == MAX_CLIENTS</label>
			<label kind="assignment" x="-983" y="-452">current_client = 0</label>
		</transition>
		<transition id="id11">
			<source ref="id1"/>
			<target ref="id9"/>
			<label kind="guard" x="-802" y="-185">current_client &gt;= MAX_CLIENTS</label>
			<label kind="assignment" x="-802" y="-165">observation_completed = true</label>
		</transition>
		<transition id="id12">
			<source ref="id1"/>
			<target ref="id2"/>
			<label kind="guard" x="-756" y="-394">current_client &lt; MAX_CLIENTS</label>
			<label kind="assignment" x="-756" y="-374">selected_client = current_client,
current_notifications = 0</label>
		</transition>
		<transition id="id13">
			<source ref="id2"/>
			<target ref="id3"/>
			<label kind="synchronisation" x="-459" y="-272">observe_start[selected_client]!</label>
		</transition>
		<transition id="id14">
			<source ref="id3"/>
			<target ref="id4"/>
			<label kind="synchronisation" x="-190" y="-330">notification[selected_client]?</label>
			<label kind="assignment" x="-190" y="-310">notification_received[selected_client] = 
notification_received[selected_client] + 1,
current_notifications = current_notifications + 1</label>
		</transition>
		<transition id="id15">
			<source ref="id4"/>
			<target ref="id5"/>
			<label kind="guard" x="-34" y="-467">current_notifications &lt; MAX_NOTIFICATIONS_PER_OBSERVATION</label>
			<label kind="synchronisation" x="-27" y="-450">coap_ack[selected_client]!</label>
			<label kind="assignment" x="-25" y="-433">ack_sent[selected_client] = ack_sent[selected_client] + 1</label>
		</transition>
		<transition id="id16">
			<source ref="id5"/>
			<target ref="id3"/>
		</transition>
		<transition id="id17">
			<source ref="id4"/>
			<target ref="id6"/>
			<label kind="guard" x="144" y="-408">current_notifications &gt;= MAX_NOTIFICATIONS_PER_OBSERVATION</label>
			<label kind="synchronisation" x="144" y="-391">coap_ack[selected_client]!</label>
			<label kind="assignment" x="144" y="-374">ack_sent[selected_client] = 
ack_sent[selected_client] + 1</label>
		</transition>
		<transition id="id18">
			<source ref="id6"/>
			<target ref="id8"/>
		</transition>
		<transition id="id19">
			<source ref="id4"/>
			<target ref="id7"/>
			<label kind="guard" x="238" y="-272">RESET_ENABLED</label>
			<label kind="synchronisation" x="238" y="-221">coap_reset[selected_client]!</label>
			<label kind="assignment" x="238" y="-255">reset_sent[selected_client] = 
reset_sent[selected_client] + 1</label>
		</transition>
		<transition id="id20">
			<source ref="id7"/>
			<target ref="id1"/>
			<label kind="assignment" x="416" y="-178">current_client = current_client + 1</label>
			<nail x="731" y="-187"/>
			<nail x="731" y="-76"/>
			<nail x="-782" y="-85"/>
		</transition>
		<transition id="id21">
			<source ref="id8"/>
			<target ref="id1"/>
			<label kind="synchronisation" x="579" y="-266">observe_stop[selected_client]!</label>
			<label kind="assignment" x="578" y="-246">current_client = current_client + 1</label>
			<nail x="731" y="-76"/>
			<nail x="-782" y="-85"/>
		</transition>
		<transition id="id22">
			<source ref="id9"/>
			<target ref="id9"/>
			<nail x="-842" y="1"/>
			<nail x="-722" y="1"/>
		</transition>
	</template>
	<template>
		<name x="5" y="5">Client</name>
		<parameter>const client_id_t id</parameter>
		<location id="id23" x="-760" y="180">
			<name x="-770" y="146">S_REGISTERED</name>
		</location>
		<location id="id24" x="-460" y="180">
			<name x="-470" y="146">S_OBSERVING</name>
		</location>
		<location id="id25" x="-180" y="180">
			<name x="-190" y="146">S_NOTIFYING</name>
			<committed/>
		</location>
		<location id="id26" x="120" y="180">
			<name x="110" y="146">S_WAIT_RESPONSE</name>
		</location>
		<init ref="id23"/>
		<transition id="id27">
			<source ref="id23"/>
			<target ref="id24"/>
			<label kind="synchronisation" x="-740" y="150">observe_start[id]?</label>
			<label kind="assignment" x="-740" y="170">client_observed[id] = true,
client_state[id] = CLIENT_STATE_OBSERVING</label>
		</transition>
		<transition id="id28">
			<source ref="id24"/>
			<target ref="id25"/>
			<label kind="guard" x="-450" y="120">client_observed[id]</label>
			<label kind="assignment" x="-450" y="140">client_state[id] = CLIENT_STATE_NOTIFYING</label>
		</transition>
		<transition id="id29">
			<source ref="id25"/>
			<target ref="id26"/>
			<label kind="synchronisation" x="-160" y="150">notification[id]!</label>
			<label kind="assignment" x="-160" y="170">notification_sent[id] = notification_sent[id] + 1</label>
		</transition>
		<transition id="id30">
			<source ref="id26"/>
			<target ref="id24"/>
			<label kind="synchronisation" x="120" y="110">coap_ack[id]?</label>
			<label kind="assignment" x="120" y="130">client_state[id] = CLIENT_STATE_OBSERVING</label>
		</transition>
		<transition id="id31">
			<source ref="id26"/>
			<target ref="id23"/>
			<label kind="synchronisation" x="120" y="230">coap_reset[id]?</label>
			<label kind="assignment" x="120" y="250">reset_received[id] = true,
client_observed[id] = false,
client_state[id] = CLIENT_STATE_REGISTERED</label>
			<nail x="120" y="300"/>
			<nail x="-760" y="300"/>
		</transition>
		<transition id="id32">
			<source ref="id24"/>
			<target ref="id23"/>
			<label kind="synchronisation" x="-760" y="230">observe_stop[id]?</label>
			<label kind="assignment" x="-760" y="250">client_observed[id] = false,
client_state[id] = CLIENT_STATE_REGISTERED</label>
			<nail x="-460" y="300"/>
			<nail x="-760" y="300"/>
		</transition>
	</template>
	<system>Client0 = Client(0);
Client1 = Client(1);
ObservationHandler1 = ObservationHandler();

system Client0, Client1, ObservationHandler1;</system>
	<queries>
		<query>
			<formula>A[] not deadlock</formula>
			<comment>Deadlock freedom.</comment>
		</query>
		<query>
			<formula>E&lt;&gt; ObservationHandler1.S_COMPLETED</formula>
			<comment>The observation workflow can complete for all clients.</comment>
		</query>
		<query>
			<formula>E&lt;&gt; notification_received[0] == MAX_NOTIFICATIONS_PER_OBSERVATION and !reset_received[0]</formula>
			<comment>A long-lived observation can receive multiple notifications before cancellation.</comment>
		</query>
		<query>
			<formula>E&lt;&gt; reset_received[0]</formula>
			<comment>A CoAP Reset path is reachable.</comment>
		</query>
		<query>
			<formula>A[] forall(c: client_id_t) (reset_received[c] imply !client_observed[c])</formula>
			<comment>After Reset, the client is no longer observed.</comment>
		</query>
		<query>
			<formula>A[] forall(c: client_id_t) notification_received[c] &lt;= MAX_NOTIFICATIONS_PER_OBSERVATION</formula>
			<comment>The bounded monitoring cycle caps notification count per client.</comment>
		</query>
	</queries>
</nta>
